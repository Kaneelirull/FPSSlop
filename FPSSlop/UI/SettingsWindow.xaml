<Window x:Class="FPSSlop.UI.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FPSSlop — Settings"
        Width="440" SizeToContent="Height"
        WindowStyle="SingleBorderWindow"
        ResizeMode="NoResize"
        Background="#0D0D0D"
        Foreground="#E0E0E0"
        FontFamily="Consolas"
        FontSize="12">

    <Window.Resources>
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="#888888"/>
            <Setter Property="Padding" Value="0,2"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="Margin" Value="0,2"/>
        </Style>
        <Style TargetType="Slider">
            <Setter Property="Margin" Value="0,4,0,8"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#1A1A1A"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#2A2A2A"/>
            <Setter Property="Margin" Value="0,2,0,6"/>
            <Setter Property="Padding" Value="4,2"/>
        </Style>
        <Style TargetType="GroupBox">
            <Setter Property="Foreground" Value="#00FFCC"/>
            <Setter Property="BorderBrush" Value="#2A2A2A"/>
            <Setter Property="Margin" Value="0,4,0,4"/>
            <Setter Property="Padding" Value="8,6"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#1A1A1A"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#2A2A2A"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Margin" Value="3,0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <!-- ComboBox with visible selected text on dark background -->
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#1A1A1A"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#2A2A2A"/>
            <Setter Property="Margin" Value="0,2,0,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Background="#1A1A1A" BorderBrush="#2A2A2A" BorderThickness="1"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Padding="6,4,24,4" HorizontalContentAlignment="Left">
                                <ContentPresenter ContentSource="SelectionBoxItem"
                                                  TextBlock.Foreground="#E0E0E0"
                                                  TextBlock.FontFamily="Consolas"
                                                  TextBlock.FontSize="12"
                                                  VerticalAlignment="Center"/>
                            </ToggleButton>
                            <Path Data="M0,0 L4,4 L8,0 Z" Fill="#888888"
                                  HorizontalAlignment="Right" VerticalAlignment="Center"
                                  Margin="0,0,8,0" IsHitTestVisible="False"/>
                            <Popup IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                   AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Border Background="#1A1A1A" BorderBrush="#2A2A2A" BorderThickness="1"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <ScrollViewer>
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Foreground" Value="#E0E0E0"/>
                        <Setter Property="Background" Value="#1A1A1A"/>
                        <Setter Property="Padding" Value="6,3"/>
                        <Style.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter Property="Background" Value="#2A2A2A"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="12">
        <StackPanel>

            <!-- GENERAL -->
            <GroupBox Header="GENERAL">
                <StackPanel>
                    <CheckBox x:Name="ChkStartWithWindows" Content="Start with Windows"/>
                    <Label Content="Poll interval (ms)"/>
                    <Slider x:Name="SliderPoll" Minimum="100" Maximum="2000" TickFrequency="100" IsSnapToTickEnabled="True"/>
                    <Label Content="Opacity"/>
                    <Slider x:Name="SliderOpacity" Minimum="0.1" Maximum="1.0" SmallChange="0.05"/>
                    <Label Content="Scale factor"/>
                    <Slider x:Name="SliderScale" Minimum="0.5" Maximum="3.0" SmallChange="0.1"/>
                </StackPanel>
            </GroupBox>

            <!-- DISPLAYS -->
            <GroupBox Header="DISPLAYS">
                <StackPanel>
                    <Label Content="Overlay target monitor"/>
                    <ComboBox x:Name="CboOverlayMonitor"/>
                </StackPanel>
            </GroupBox>

            <!-- FPS TARGET -->
            <GroupBox Header="FPS TARGET">
                <StackPanel>
                    <Label Content="Track FPS for process"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox x:Name="CboFpsTarget" Grid.Column="0" Margin="0,2,4,6"/>
                        <Button x:Name="BtnRefreshProcesses" Grid.Column="1" Content="↺" Width="28"
                                Margin="0,2,0,6" Click="BtnRefreshProcesses_Click" ToolTip="Refresh process list"/>
                    </Grid>
                    <Label x:Name="LblAutoTarget" Content="Auto targeting: —"
                           Foreground="#00FFCC" Padding="0,0,0,2"/>
                </StackPanel>
            </GroupBox>

            <!-- METRICS -->
            <GroupBox Header="METRICS">
                <WrapPanel>
                    <CheckBox x:Name="ChkFps"       Content="FPS"          Width="130"/>
                    <CheckBox x:Name="ChkFrameTime" Content="Frame time"   Width="130"/>
                    <CheckBox x:Name="ChkLow1"      Content="1% low"       Width="130"/>
                    <CheckBox x:Name="ChkLow01"     Content="0.1% low"     Width="130"/>
                    <CheckBox x:Name="ChkGpuUsage"  Content="GPU usage"    Width="130"/>
                    <CheckBox x:Name="ChkGpuTemp"   Content="GPU temp"     Width="130"/>
                    <CheckBox x:Name="ChkGpuCore"   Content="GPU core clk" Width="130"/>
                    <CheckBox x:Name="ChkGpuMem"    Content="GPU mem clk"  Width="130"/>
                    <CheckBox x:Name="ChkVram"      Content="VRAM"         Width="130"/>
                    <CheckBox x:Name="ChkPower"     Content="Power draw"   Width="130"/>
                    <CheckBox x:Name="ChkCpuUsage"  Content="CPU usage"    Width="130"/>
                    <CheckBox x:Name="ChkCpuTemp"   Content="CPU temp"     Width="130"/>
                    <CheckBox x:Name="ChkCpuClock"  Content="CPU clock"    Width="130"/>
                    <CheckBox x:Name="ChkRam"       Content="RAM"          Width="130"/>
                </WrapPanel>
            </GroupBox>

            <!-- ROW ORDER -->
            <GroupBox Header="ROW ORDER">
                <StackPanel>
                    <Label Content="Drag rows or use arrows to reorder"/>
                    <StackPanel x:Name="RowOrderPanel" Orientation="Vertical" Margin="0,4,0,0"/>
                </StackPanel>
            </GroupBox>

            <!-- THEME -->
            <GroupBox Header="THEME">
                <StackPanel>
                    <Label Content="Accent colour (hex)"/>
                    <TextBox x:Name="TxtAccentColor" MaxLength="7"/>
                    <Label Content="Font size"/>
                    <Slider x:Name="SliderFontSize" Minimum="9" Maximum="20" TickFrequency="1" IsSnapToTickEnabled="True"/>
                    <CheckBox x:Name="ChkCompact" Content="Compact mode"/>
                    <CheckBox x:Name="ChkPositionLocked" Content="Lock overlay position" Margin="0,6,0,0"/>
                </StackPanel>
            </GroupBox>

            <!-- BUTTONS -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                <Button x:Name="BtnApply" Content="Apply" Click="BtnApply_Click"/>
                <Button x:Name="BtnClose" Content="Close" Click="BtnClose_Click"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Window>
